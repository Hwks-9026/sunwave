{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SW Math Language",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.line.double-slash.sw", "match": "//.*$" }]
    },
    "keywords": {
      "patterns": [{
        "name": "keyword.control.sw",
        "match": "\\b(loop|recur|module|export|import)\\b"
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.sw",
        "match": "\\b\\d+(\\.\\d+)?\\b"
      }]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.assignment.sw", "match": ":=" },
        { "name": "keyword.operator.comparison.sw", "match": "==|>=|<=|>|<" },
        { "name": "keyword.operator.arithmetic.sw", "match": "\\+|\\-|\\*|/|%" },
        { "name": "keyword.control.conditional.sw", "match": "\\?|:" },
        { "name": "punctuation.definition.parameters.sw", "match": "\\|" }
      ]
    }
  },
  "scopeName": "source.sw"
}
